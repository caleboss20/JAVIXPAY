-29T05:09:38.071Z","0.0.6":"2013-03-29T07:43:06.658Z","0.0.7":"2014-05-01T18:23:53.561Z","0.0.8":"2015-05-22T20:10:10.382Z"},"bugs":{"url":"https://github.com/benmonro/android/issues"},"author":{"name":"Ben Monro"},"license":"BSD","homepage":"https://github.com/benmonro/android","keywords":["android","adb"],"repository":{"url":"git://github.com/benmonro/android.git","type":"git"},"description":"various android utils & commands for node","maintainers":[{"name":"benmonro","email":"ben.monro@gmail.com"}],"readme":"android\n=======\n\na node module for adb &amp; android\n\nExamples:\n\n```javascript\nvar adb = require(\"android\");\n```\n\nGet attached device id\n----------------------\n```javascript\nadb.firstDevice(function(deviceId){\n\tif(deviceId) {\n\t\t//there's a device attached, do cool stuff\n\t} else {\n\t\t//no device attached\n\t}\n});\n```\n\nChecking to see if a package is installed (wildcards allowed)\n-------------------------------------------------------------\n```javascript\nadb.isInstalled(\"com.example.*\", function(isInstalled) {\n\tif(isInstalled) {\n\t\t//do cool stuff\n\t}\n});\n```\n\nInstalling an APK\n-----------------\n\n```javascript\nadb.install(\"/path/to/my.apk\", function() {\n\t//do cool stuff\n});\n```\n\nPushing a file\n--------------\n```javascript\nadb.push(\"/path/to/src\", \"/path/to/target\", function (err) {\n\tif(!err) {\n\t\t//do cool stuff\n\t}\n});\n```\n\nSending a broadcast\n-------------------\n```javascript\nvar options = {action:\"com.example.ACTION_JACKSON\", extras:{key:\"lime\", pie: \"good\"};\n\nadb.sendBroadcast(options, function(response){\n\tconsole.log(\"response data: \" + response.data);\n\tconsole.log(\"response message: \" + response.message);\n});\n```","readmeFilename":"README.md","users":{"gooer":true,"jixuu":true,"chorong":true,"edethor":true,"gabfest":true,"mushfau":true,"nillcon":true,"mrleonxm":true,"s2life97":true,"ismailaek":true,"nnavavzla":true,"oswaldflm":true,"snowdream":true,"yakun.cyk":true